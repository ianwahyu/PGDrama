---
const { eyebrow = "SPlay Web", title, subtitle } = Astro.props;
---

<header class="mb-7">
  <div class="flex items-center justify-between gap-3">
    <a href="/" class="inline-flex items-center gap-2 rounded-full border border-cream-50/10 bg-cream-50/8 px-3 py-2 text-sm font-bold text-cream-50">
      <span class="grid size-8 place-items-center rounded-full bg-sage-300 text-ink-950">PG</span>
      <span>PGDrama</span>
    </a>
    <div class="hidden items-center gap-2 md:flex">
      <a class="rounded-full px-4 py-2 text-sm font-semibold text-cream-100/75 hover:bg-cream-50/10" href="/favorites">Favorit</a>
      <a class="rounded-full px-4 py-2 text-sm font-semibold text-cream-100/75 hover:bg-cream-50/10" href="/history">History</a>
    </div>
  </div>
  <div class="mt-8 max-w-3xl">
    <p class="text-sm font-bold uppercase tracking-[0.28em] text-peach-300">{eyebrow}</p>
    <h1 class="mt-3 text-4xl font-black tracking-tight text-cream-50 sm:text-5xl">{title}</h1>
    {subtitle && <p class="mt-4 text-base leading-7 text-cream-100/72 sm:text-lg">{subtitle}</p>}
  </div>
</header>
