---
const { page = 1, totalPages = 1, baseUrl } = Astro.props;
const current = Number(page);
const total = Number(totalPages);
const previous = current > 1 ? new URL(baseUrl) : null;
const next = current < total ? new URL(baseUrl) : null;
previous?.searchParams.set("page", String(current - 1));
next?.searchParams.set("page", String(current + 1));
const previousHref = previous ? `${previous.pathname}${previous.search}` : "#";
const nextHref = next ? `${next.pathname}${next.search}` : "#";
---

<div class="mt-8 flex flex-wrap items-center justify-between gap-3">
  <a class:list={["px-4 py-3 text-sm sm:px-5", previous ? "brutal-button-secondary" : "pointer-events-none border-2 border-content-50 bg-base-800 text-content-50/35 px-4 py-3 font-black sm:px-5"]} href={previousHref}>
    Sebelumnya
  </a>
  <span class="brutal-sticker order-first w-full bg-yellow-500 px-3 py-2 text-center text-sm font-black sm:order-none sm:w-auto">Page {current} / {Math.max(total, 1)}</span>
  <a class:list={["px-4 py-3 text-sm sm:px-5", next ? "brutal-button" : "pointer-events-none border-2 border-content-50 bg-base-800 text-content-50/35 px-4 py-3 font-black sm:px-5"]} href={nextHref}>
    Berikutnya
  </a>
</div>
