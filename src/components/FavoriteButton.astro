---
const { item } = Astro.props;
---

<button
  class="brutal-button is-pink px-5 py-3 text-sm"
  type="button"
  data-favorite-button
  data-item={JSON.stringify(item)}
>
  Simpan Favorit
</button>

<script>
  import { isFavorite, toggleFavorite } from "../lib/localData";

  document.querySelectorAll("[data-favorite-button]").forEach((button) => {
    const item = JSON.parse(button.getAttribute("data-item") || "{}");
    const sync = () => {
      button.textContent = isFavorite(item.id, item.type) ? "Favorit Tersimpan" : "Simpan Favorit";
    };
    sync();
    button.addEventListener("click", () => {
      toggleFavorite(item);
      sync();
    });
  });
</script>
