---
const { error } = Astro.props;
---

{
  error && (
    <div class="border-2 border-content-50 bg-pink-500 p-5 text-base-950 shadow-[5px_5px_0_var(--panel-shadow)]">
      <p class="font-black">Tidak bisa memuat data</p>
      <p class="mt-1 text-sm font-bold">{error.message}</p>
    </div>
  )
}
