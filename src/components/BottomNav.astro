---
const links = [
  { href: "/", label: "Home", icon: "⌂" },
  { href: "/dramas", label: "Drama", icon: "▶" },
  { href: "/favorites", label: "Favorit", icon: "♡" },
  { href: "/history", label: "History", icon: "◷" }
];
---

<nav class="fixed inset-x-0 bottom-0 z-50 border-t border-content-50/10 bg-base-950/88 px-3 pb-[calc(env(safe-area-inset-bottom)+0.6rem)] pt-2 backdrop-blur-2xl md:hidden">
  <div class="mx-auto grid max-w-md grid-cols-4 gap-1">
    {
      links.map((link) => (
        <a class="flex min-h-12 flex-col items-center justify-center rounded-2xl text-xs font-semibold text-content-100/70 transition hover:bg-content-50/10 hover:text-content-50" href={link.href}>
          <span class="text-lg leading-none">{link.icon}</span>
          <span>{link.label}</span>
        </a>
      ))
    }
  </div>
</nav>
