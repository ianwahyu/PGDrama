---
import type { EpisodeNavigationItem } from "@lib/watch";
import type { SubtitleTrack } from "@lib/types";

const { src, title, poster, content, nextEpisode, previousEpisode, subtitle, subtitles = [] } = Astro.props as {
  src?: string | null;
  title: string;
  poster?: string | null;
  content: Record<string, unknown>;
  nextEpisode?: EpisodeNavigationItem | null;
  previousEpisode?: EpisodeNavigationItem | null;
  subtitle?: string | null;
  subtitles?: SubtitleTrack[];
};

const rawSubtitleSrc = typeof subtitle === "string" ? subtitle.trim() : "";
const subtitleSrc = ["", "null", "undefined", "none", "-"].includes(rawSubtitleSrc.toLowerCase()) ? "" : rawSubtitleSrc;
const subtitleTracks = subtitles.length > 0 ? subtitles : subtitleSrc ? [{ label: "Indonesia", url: subtitleSrc, language: "id" }] : [];
---

<section class="soft-panel relative overflow-hidden">
  <div class="group/player relative aspect-video bg-black text-white" data-player-shell data-controls-visible="true" tabindex="0">
    {
      src ? (
        <video
          id="video-player"
          class="h-full w-full bg-black object-contain"
          src={src}
          poster={poster}
          playsinline
          preload="metadata"
          data-content={JSON.stringify(content)}
          data-previous-url={previousEpisode?.url || ""}
          data-next-url={nextEpisode?.url || ""}
        >
          {subtitleTracks.map((track, index) => (
            <track
              kind="subtitles"
              src={track.url}
              label={track.label}
              srclang={track.language || "id"}
              default={index === 0}
              data-subtitle-index={index}
            />
          ))}
        </video>
      ) : (
        <div class="grid h-full place-items-center border-b-2 border-content-50 bg-base-800 p-6 text-center font-black text-content-100">
          Video belum tersedia untuk plan/API saat ini.
        </div>
      )
    }
    {(previousEpisode || nextEpisode) && (
      <div class="player-chrome absolute inset-x-2 top-2 z-20 flex items-center justify-between gap-2 transition sm:inset-x-3 sm:top-3">
        {previousEpisode ? (
          <a class="inline-flex min-h-9 items-center gap-1 border-2 border-white bg-black px-2 text-xs font-black text-white shadow-[2px_2px_0_#fff] hover:bg-primary-500 hover:text-base-950 sm:min-h-10 sm:gap-2 sm:px-3 sm:text-sm" href={previousEpisode.url} rel="prev">
            <svg class="size-4 sm:size-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="19 20 9 12 19 4 19 20"/><line x1="5" y1="19" x2="5" y2="5"/></svg>
            <span>Ep {previousEpisode.index}</span>
          </a>
        ) : (
          <span></span>
        )}
        {nextEpisode && (
          <a class="inline-flex min-h-9 items-center gap-1 border-2 border-white bg-primary-500 px-2 text-xs font-black text-base-950 shadow-[2px_2px_0_#fff] hover:bg-pink-500 sm:min-h-10 sm:gap-2 sm:px-3 sm:text-sm" href={nextEpisode.url} rel="next">
            <span>Ep {nextEpisode.index}</span>
            <svg class="size-4 sm:size-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" y1="5" x2="19" y2="19"/></svg>
          </a>
        )}
      </div>
    )}

    {src && (
      <>
        <button
          class="absolute left-1/2 top-1/2 z-20 grid size-16 -translate-x-1/2 -translate-y-1/2 place-items-center border-2 border-white bg-primary-500 text-3xl font-black text-base-950 shadow-[4px_4px_0_#fff] transition hover:bg-pink-500 sm:size-20"
          type="button"
          data-player-action="play"
          aria-label="Play atau pause"
        >
          <svg data-icon-play class="size-8 sm:size-10" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"/></svg>
          <svg data-icon-pause class="size-8 sm:size-10 hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
        </button>

        <div class="player-chrome absolute inset-x-0 bottom-0 z-30 bg-black/88 p-2 transition sm:p-3" data-custom-controls>
          <input class="mb-2 h-3 w-full accent-[var(--primary-500)]" type="range" min="0" max="100" value="0" step="0.1" data-player-seek aria-label="Seek video" />
          <div class="grid grid-cols-5 gap-2 sm:flex sm:flex-wrap sm:items-center" data-player-actions>
            <button class="border-2 border-white bg-primary-500 p-2 text-base-950 flex items-center justify-center transition hover:bg-pink-500" type="button" data-player-action="play" aria-label="Play/Pause">
              <svg data-icon-play class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"/></svg>
              <svg data-icon-pause class="size-4 hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
            </button>
            <button class="border-2 border-white bg-black p-2 text-white flex items-center justify-center transition hover:bg-content-800" type="button" data-player-action="seek-back" title="Mundur 10 detik">
              <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 1 3 5 7 9"/><text x="12" y="16" font-size="9" font-weight="bold" fill="currentColor" stroke="none" text-anchor="middle">10</text></svg>
            </button>
            <button class="border-2 border-white bg-black p-2 text-white flex items-center justify-center transition hover:bg-content-800" type="button" data-player-action="seek-forward" title="Maju 10 detik">
              <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11V9a4 4 0 0 0-4-4H3"/><polyline points="17 1 21 5 17 9"/><text x="12" y="16" font-size="9" font-weight="bold" fill="currentColor" stroke="none" text-anchor="middle">10</text></svg>
            </button>
            <span class="col-span-2 text-xs font-black flex items-center justify-center sm:justify-start sm:px-2 sm:flex-1" data-player-time>0:00 / 0:00</span>
            
            <label class="col-span-3 flex items-center gap-2 text-xs font-black sm:col-auto">
              <svg class="size-4 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
              <input class="w-full min-w-16 accent-[var(--primary-500)] sm:w-20" type="range" min="0" max="1" value="1" step="0.05" data-player-volume aria-label="Volume" />
            </label>
            <select class="col-span-2 border-2 border-white bg-black px-2 py-2 text-xs font-black text-white sm:col-auto" data-player-speed aria-label="Kecepatan video">
              <option value="0.75">0.75x</option>
              <option value="1" selected>1x</option>
              <option value="1.25">1.25x</option>
              <option value="1.5">1.5x</option>
              <option value="2">2x</option>
            </select>
            {subtitleTracks.length > 0 && (
              <select class="col-span-5 border-2 border-white bg-black px-2 py-2 text-xs font-black text-white sm:col-auto" data-subtitle-control aria-label="Subtitle">
                <option value="off">Subtitle mati</option>
                {subtitleTracks.map((track, index) => (
                  <option value={index} selected={index === 0}>{track.label}</option>
                ))}
              </select>
            )}
            
            <div class="col-span-5 flex gap-2 justify-between sm:col-auto sm:justify-start">
              <button class="border-2 border-white bg-black p-2 text-white flex items-center justify-center transition hover:bg-content-800 disabled:opacity-40" type="button" data-player-action="autonext" title="Auto Next" disabled={!nextEpisode}>
                <svg data-icon-auto class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
              </button>
              <button class="border-2 border-white bg-black p-2 text-white flex items-center justify-center transition hover:bg-content-800 disabled:opacity-40" type="button" data-player-action="previous" title="Previous" disabled={!previousEpisode}>
                <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="19 20 9 12 19 4 19 20"/><line x1="5" y1="19" x2="5" y2="5"/></svg>
              </button>
              <button class="border-2 border-white bg-primary-500 p-2 text-base-950 flex items-center justify-center transition hover:bg-pink-500 disabled:opacity-40" type="button" data-player-action="next" title="Next" disabled={!nextEpisode}>
                <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" y1="5" x2="19" y2="19"/></svg>
              </button>
              <button class="border-2 border-white bg-black p-2 text-white flex items-center justify-center transition hover:bg-content-800 sm:hidden" type="button" data-player-action="rotate" title="Landscape">
                <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="12" height="20" x="6" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
              </button>
              <button class="border-2 border-white bg-black p-2 text-white flex items-center justify-center transition hover:bg-content-800" type="button" data-player-action="fullscreen" title="Fullscreen">
                <svg data-icon-full class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
                <svg data-icon-exit class="size-4 hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3v3a2 2 0 0 1-2 2H3m18 0h-3a2 2 0 0 1-2-2V3m0 18v-3a2 2 0 0 1 2-2h3M3 16h3a2 2 0 0 1 2 2v3"/></svg>
              </button>
            </div>
          </div>
        </div>
      </>
    )}

    <div class="absolute inset-x-3 bottom-24 z-40 hidden border-2 border-content-50 bg-yellow-500 p-3 text-sm font-black text-base-950 sm:bottom-28" data-autonext-countdown>
      Episode selesai. Lanjut otomatis dalam <span data-autonext-seconds>5</span> detik.
      <button class="ml-2 border-2 border-content-50 bg-base-900 px-2 py-1 text-xs font-black text-content-50" type="button" data-player-action="cancel-autonext">Batal</button>
    </div>
  </div>
  <div class="border-t-2 border-content-50 p-3 sm:p-4">
    <p class="brutal-sticker inline-block bg-primary-500 px-2 py-1 text-xs font-black uppercase">Sekarang diputar</p>
    <div class="mt-2">
      <h1 class="text-xl font-black leading-tight sm:text-2xl">{title}</h1>
    </div>
    <p class="mt-3 text-xs font-bold text-content-100">Shortcut: spasi play/pause, J/L atau panah kiri/kanan untuk 10 detik, S subtitle, N next, P previous, F fullscreen.</p>
  </div>
</section>

<script>
  import "../lib/player";
</script>

<style>
  [data-player-shell].is-rotated {
    position: fixed;
    top: 50%;
    left: 50%;
    width: 100vh;
    height: 100vw;
    transform: translate(-50%, -50%) rotate(90deg);
    z-index: 9999;
  }
</style>
