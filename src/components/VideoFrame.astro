---
const { src, title, poster, content } = Astro.props;
---

<section class="soft-panel overflow-hidden rounded-[1.6rem]">
  <div class="aspect-video bg-black">
    {
      src ? (
        <video
          id="video-player"
          class="h-full w-full"
          src={src}
          poster={poster}
          controls
          playsinline
          preload="metadata"
          data-content={JSON.stringify(content)}
        />
      ) : (
        <div class="grid h-full place-items-center p-6 text-center text-cream-100/65">
          Video belum tersedia untuk plan/API saat ini.
        </div>
      )
    }
  </div>
  <div class="p-4">
    <p class="text-sm font-bold text-peach-300">Sekarang diputar</p>
    <h1 class="mt-1 text-2xl font-black">{title}</h1>
  </div>
</section>

<script>
  import "../lib/player";
</script>
