---
import type { EpisodeItem } from "@lib/types";

const { episodes = [], watchBase = "", contentId = "", contentType = "" } = Astro.props as {
  episodes: EpisodeItem[];
  watchBase: string;
  contentId: string;
  contentType: string;
};
---

<section class="mt-8">
  <h2 class="brutal-sticker mb-4 inline-block bg-yellow-500 px-3 py-1 text-2xl font-black">Episode</h2>
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3" data-episode-list data-content-id={contentId} data-content-type={contentType}>
    {
      episodes.map((episode) => {
        const isTitleRedundant = episode.title.toLowerCase() === `episode ${episode.index}` || episode.title.toLowerCase() === `ep ${episode.index}` || episode.title === `${episode.index}`;
        return (
          <a class="episode-link brutal-card flex items-center justify-between gap-3 p-3 sm:p-4" href={`${watchBase}/${episode.index}`} data-episode-id={episode.id} data-episode-index={episode.index}>
            <div class="flex min-w-0 items-center gap-3">
              <div class="grid size-8 place-items-center border-2 border-content-50 bg-primary-500 text-xs font-black text-base-950">{episode.index}</div>
              <div class="min-w-0">
                <p class="truncate text-sm font-black">{isTitleRedundant ? `Episode ${episode.index}` : episode.title}</p>
              </div>
            </div>
            <span class="watched-pill hidden shrink-0 border-2 border-content-50 bg-pink-500 px-2 py-1 text-[0.65rem] font-black text-base-950">Sudah</span>
          </a>
        );
      })
    }
  </div>
</section>

<script>
  import { getHistory } from "../lib/localData";

  const list = document.querySelector("[data-episode-list]");
  if (list) {
    const contentId = list.getAttribute("data-content-id");
    const contentType = list.getAttribute("data-content-type");
    const watched = new Set(
      getHistory()
        .filter((entry) => entry.id === contentId && entry.type === contentType && entry.progress_seconds > 10)
        .map((entry) => String(entry.episode_index))
    );

    list.querySelectorAll(".episode-link").forEach((link) => {
      const index = link.getAttribute("data-episode-index");
      if (index && watched.has(index)) {
        link.querySelector(".watched-pill")?.classList.remove("hidden");
      }
    });
  }
</script>
