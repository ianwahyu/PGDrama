---
import "../styles/global.css";
import BottomNav from "./BottomNav.astro";

const {
  title = "PGDrama",
  description = "Katalog streaming ringan untuk SPlay.",
  compact = false
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="preconnect" href="https://api.splay.id" />
    <title>{title}</title>
    <script is:inline>
      const t = localStorage.getItem('theme');
      if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="tap-highlight text-content-50">
    <div class:list={["mx-auto min-h-dvh w-full max-w-6xl px-3 pb-28 pt-4 sm:px-6 lg:px-8", compact && "max-w-4xl"]}>
      <slot />
    </div>
    <BottomNav />
  </body>
</html>
