---
import AppShell from "@components/AppShell.astro";
import ContentRail from "@components/ContentRail.astro";
import Header from "@components/Header.astro";
import SearchBar from "@components/SearchBar.astro";
import { BACA_CATEGORIES, CONTENT_TYPES } from "@lib/content";
import { getPopularDramas, getTrendingDramas } from "@lib/splay";
import type { NormalizedList } from "@lib/types";

let popular: Pick<NormalizedList, "items"> = { items: [] };
let trending: Pick<NormalizedList, "items"> = { items: [] };

try {
  [popular, trending] = await Promise.all([getPopularDramas(), getTrendingDramas()]);
} catch {
  popular = { items: [] };
  trending = { items: [] };
}
---

<AppShell title="PGDrama - SPlay ringan">
  <Header
    title="Nonton ringan, katalog cepat, nyaman di mobile."
    subtitle="Jelajahi drama pendek, anime, movie, drakor, dan manga dari SPlay dalam tampilan soft-modern yang hemat resource."
  />

  {trending.items.length > 0 && (
    <section class="mb-8 w-full overflow-hidden bg-base-900 poster-shadow sm:mb-10">
      <div class="flex snap-x snap-mandatory overflow-x-auto scroll-smooth [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
        {trending.items.slice(0, 5).map((item, index) => (
          <a href={`/dramas/${item.id}`} class="relative min-w-full snap-center block aspect-[4/5] sm:aspect-[16/9] md:aspect-[21/9]">
            <img class="absolute inset-0 h-full w-full object-cover shimmer" src={item.cover_url} alt={item.title} loading="eager" />
            <div class="absolute inset-0 bg-black/25"></div>
            <div class="absolute bottom-0 left-0 w-full border-t-2 border-content-50 bg-base-900 p-4 md:w-2/3 md:border-r-2 md:p-7">
              <span class="brutal-sticker mb-3 inline-block bg-primary-500 px-3 py-1 text-xs font-black">Trending #{index + 1}</span>
              <h2 class="line-clamp-2 text-xl font-black leading-tight text-content-50 sm:text-2xl md:text-4xl">{item.title}</h2>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <SearchBar />

  <section class="my-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {
      CONTENT_TYPES.map((content) => (
        <a class="brutal-card group p-4 sm:p-5" href={content.href}>
          <span class:list={["mb-5 block size-5 border-2 border-content-50", content.accent]} />
          <p class="text-lg font-black">{content.label}</p>
          <p class="mt-2 border-t-2 border-content-50 pt-2 text-sm font-bold text-content-100">Buka katalog</p>
        </a>
      ))
    }
  </section>

  <section class="my-8">
    <h2 class="brutal-sticker mb-4 inline-block bg-pink-500 px-3 py-1 text-2xl font-black">Baca</h2>
    <div class="grid gap-3 sm:grid-cols-3">
      {BACA_CATEGORIES.map((item) => <a class="brutal-card is-yellow p-4 font-black" href={item.href}>{item.label}</a>)}
    </div>
  </section>

  <ContentRail title="Drama populer" items={popular.items} basePath="/dramas" />
  <ContentRail title="Lagi trending" items={trending.items} basePath="/dramas" />
</AppShell>
