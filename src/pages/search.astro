---
import AppShell from "@components/AppShell.astro";
import EmptyState from "@components/EmptyState.astro";
import ErrorState from "@components/ErrorState.astro";
import Header from "@components/Header.astro";
import PosterCard from "@components/PosterCard.astro";
import SearchBar from "@components/SearchBar.astro";
import { itemHref } from "@lib/content";
import { searchContent } from "@lib/splay";

const q = Astro.url.searchParams.get("q") ?? "";
const result = q ? await searchContent(q) : { items: [], meta: { page: 1, per_page: 20, total: 0, total_pages: 0 } };
---

<AppShell title={`Cari ${q || ""} - PGDrama`}>
  <Header eyebrow="Search" title="Cari tontonan" subtitle="Pencarian dibuat ringan dan langsung mengambil metadata dari SPlay lewat server." />
  <SearchBar q={q} />
  <div class="mt-8">
    <ErrorState error={result.error} />
    {
      result.items.length ? (
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
          {result.items.map((item) => <PosterCard item={item} href={itemHref(item)} />)}
        </div>
      ) : (
        <EmptyState title={q ? "Tidak ketemu" : "Mulai cari"} message={q ? "Coba kata kunci lain." : "Masukkan judul atau kata kunci di atas."} />
      )
    }
  </div>
</AppShell>
