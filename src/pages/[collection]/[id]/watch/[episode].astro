---
import AppShell from "@components/AppShell.astro";
import VideoFrame from "@components/VideoFrame.astro";
import { isContentType } from "@lib/content";
import { getDetail, getEpisode } from "@lib/splay";

const collection = Astro.params.collection ?? "";
const id = Astro.params.id ?? "";
const episodeIndex = Astro.params.episode ?? "";

if (!isContentType(collection)) {
  return Astro.redirect("/");
}

const [detail, episode] = await Promise.all([getDetail(collection, id), getEpisode(collection, id, episodeIndex)]);
const item = detail.item;
const videoSrc = episode?.video_url || Object.values(episode?.qualities ?? {})[0] || null;
---

<AppShell title={`${item.title} Episode ${episodeIndex} - PGDrama`} compact>
  <a class="mb-5 inline-flex rounded-full bg-cream-50/8 px-4 py-2 text-sm font-bold text-cream-100/70" href={`/${collection}/${id}`}>← Kembali ke detail</a>
  <VideoFrame
    src={videoSrc}
    poster={item.cover_url}
    title={`${item.title} - Episode ${episode?.index ?? episodeIndex}`}
    content={{
      id: item.id,
      type: collection,
      episode_id: episode?.id ?? episodeIndex,
      episode_index: episode?.index ?? Number(episodeIndex),
      title: item.title,
      cover_url: item.cover_url
    }}
  />
</AppShell>
