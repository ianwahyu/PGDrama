---
import AppShell from "@components/AppShell.astro";
import EpisodeList from "@components/EpisodeList.astro";
import FavoriteButton from "@components/FavoriteButton.astro";
import ProgressPill from "@components/ProgressPill.astro";
import { isContentType, labelFor } from "@lib/content";
import { getDetail, getEpisodes } from "@lib/splay";

const collection = Astro.params.collection ?? "";
const id = Astro.params.id ?? "";

if (!isContentType(collection)) {
  return Astro.redirect("/");
}

const [detail, episodes] = await Promise.all([getDetail(collection, id), getEpisodes(collection, id).catch(() => [])]);
const item = detail.item;
---

<AppShell title={`${item.title} - PGDrama`} compact>
  <a class="mb-5 inline-flex rounded-full bg-content-50/8 px-4 py-2 text-sm font-bold text-content-100/70" href={`/${collection}`}>← {labelFor(collection)}</a>
  <section class="grid gap-6 md:grid-cols-[15rem_1fr]">
    <div class="poster-shadow overflow-hidden rounded-[1.6rem] bg-base-800">
      <img class="aspect-[2/3] h-full w-full object-cover" src={item.cover_url || ""} alt={item.title} loading="eager" />
    </div>
    <div class="soft-panel rounded-[1.8rem] p-6">
      <p class="text-sm font-bold uppercase tracking-[0.24em] text-pink-300">{labelFor(collection)}</p>
      <h1 class="mt-3 text-4xl font-black tracking-tight">{item.title}</h1>
      <p class="mt-4 leading-7 text-content-100/70">{item.description || "Deskripsi belum tersedia."}</p>
      <div class="mt-5 flex flex-wrap gap-2">
        {item.provider && <span class="rounded-full bg-content-50/10 px-3 py-1 text-xs font-bold">{item.provider}</span>}
        {item.language && <span class="rounded-full bg-content-50/10 px-3 py-1 text-xs font-bold">{item.language}</span>}
        {item.episode_count && <span class="rounded-full bg-content-50/10 px-3 py-1 text-xs font-bold">{item.episode_count} episode</span>}
      </div>
      <div class="mt-7 flex flex-wrap gap-3">
        <FavoriteButton item={{ id: item.id, type: collection, title: item.title, cover_url: item.cover_url, provider: item.provider }} />
        <ProgressPill contentId={item.id} contentType={collection} />
      </div>
    </div>
  </section>
  <EpisodeList episodes={episodes} watchBase={`/${collection}/${id}/watch`} contentId={id} contentType={collection} />
</AppShell>
