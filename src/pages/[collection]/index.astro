---
import AppShell from "@components/AppShell.astro";
import EmptyState from "@components/EmptyState.astro";
import ErrorState from "@components/ErrorState.astro";
import Header from "@components/Header.astro";
import Pagination from "@components/Pagination.astro";
import PosterCard from "@components/PosterCard.astro";
import SearchBar from "@components/SearchBar.astro";
import { isContentType, itemHref, labelFor } from "@lib/content";
import { listContent, toQuery } from "@lib/splay";

const collection = Astro.params.collection ?? "";

if (!isContentType(collection)) {
  return Astro.redirect("/");
}

const params = toQuery({
  page: Astro.url.searchParams.get("page") ?? 1,
  per_page: Astro.url.searchParams.get("per_page") ?? 24,
  type: Astro.url.searchParams.get("type"),
  genre: Astro.url.searchParams.get("genre"),
  language: Astro.url.searchParams.get("language"),
  sort_by: Astro.url.searchParams.get("sort_by"),
  sort_order: Astro.url.searchParams.get("sort_order")
});

const result = await listContent(collection, params);
---

<AppShell title={`${labelFor(collection)} - PGDrama`}>
  <Header eyebrow="Katalog" title={labelFor(collection)} subtitle="Browse ringan dengan pagination supaya tetap hemat data dan RAM." />
  <SearchBar />

  <form class="soft-panel mb-6 grid gap-3 p-3 sm:grid-cols-2 lg:grid-cols-4" method="get">
    <input class="brutal-input px-4 py-3 text-sm font-black outline-none" name="language" placeholder="language: id/en/ko" value={Astro.url.searchParams.get("language") ?? ""} />
    <input class="brutal-input px-4 py-3 text-sm font-black outline-none" name="genre" placeholder="genre/tag" value={Astro.url.searchParams.get("genre") ?? ""} />
    <select class="brutal-input px-4 py-3 text-sm font-black outline-none" name="sort_by">
      <option value="">Sort default</option>
      {["updated_at", "play_count", "title", "chapter_count", "created_at"].map((value) => <option value={value} selected={Astro.url.searchParams.get("sort_by") === value}>{value}</option>)}
    </select>
    <button class="brutal-button px-4 py-3 text-sm">Filter</button>
  </form>

  <ErrorState error={result.error} />
  {
    result.items.length ? (
      <>
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
          {result.items.map((item) => <PosterCard item={item} href={itemHref(item)} />)}
        </div>
        <Pagination page={result.meta.page} totalPages={result.meta.total_pages} baseUrl={Astro.url} />
      </>
    ) : (
      <EmptyState />
    )
  }
</AppShell>
