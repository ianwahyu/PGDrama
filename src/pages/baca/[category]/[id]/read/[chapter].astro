---
import AppShell from "@components/AppShell.astro";
import { isBacaCategory } from "@lib/content";
import { getBacaChapters, getBacaDetail } from "@lib/splay";

const category = Astro.params.category ?? "";
const id = Astro.params.id ?? "";
const chapter = Astro.params.chapter ?? "";

if (!isBacaCategory(category)) {
  return Astro.redirect("/");
}

const [detail, chapters] = await Promise.all([getBacaDetail(category, id), getBacaChapters(category, id).catch(() => [])]);
const item = detail.item;
const current = chapters.find((entry) => String(entry.index) === chapter || entry.id === chapter);
const images = Object.values((current?.raw?.images ?? current?.raw?.pages ?? current?.raw?.qualities ?? {}) as Record<string, string>);
---

<AppShell title={`${item.title} Chapter ${chapter} - PGDrama`} compact>
  <a class="brutal-button-secondary mb-5 inline-flex px-4 py-2 text-sm" href={`/baca/${category}/${id}`}>&larr; Kembali ke detail</a>
  <header class="soft-panel mb-5 p-4 sm:p-5">
    <p class="brutal-sticker inline-block bg-pink-500 px-3 py-1 text-sm font-black">Chapter {chapter}</p>
    <h1 class="mt-3 text-2xl font-black leading-tight sm:text-3xl">{item.title}</h1>
  </header>
  <div class="space-y-4">
    {
      images.length ? (
        images.map((src) => <img class="mx-auto w-full border-2 border-content-50 bg-base-800 shadow-[5px_5px_0_var(--panel-shadow)]" src={src} alt={`${item.title} chapter ${chapter}`} loading="lazy" />)
      ) : (
        <div class="soft-panel p-8 text-center font-black text-content-100">Halaman chapter belum tersedia.</div>
      )
    }
  </div>
</AppShell>
