---
import AppShell from "@components/AppShell.astro";
import FavoriteButton from "@components/FavoriteButton.astro";
import { isBacaCategory, labelFor } from "@lib/content";
import { getBacaChapters, getBacaDetail } from "@lib/splay";

const category = Astro.params.category ?? "";
const id = Astro.params.id ?? "";
if (!isBacaCategory(category)) {
  return Astro.redirect("/");
}

const [detail, chapters] = await Promise.all([getBacaDetail(category, id), getBacaChapters(category, id).catch(() => [])]);
const item = detail.item;
---

<AppShell title={`${item.title} - PGDrama`} compact>
  <a class="brutal-button-secondary mb-5 inline-flex px-4 py-2 text-sm" href={`/baca/${category}`}>&larr; {labelFor(category)}</a>
  <section class="grid gap-6 md:grid-cols-[15rem_1fr]">
    <img class="poster-shadow aspect-[2/3] object-cover" src={item.cover_url || ""} alt={item.title} />
    <div class="soft-panel p-4 sm:p-6">
      <p class="brutal-sticker inline-block bg-pink-500 px-3 py-1 text-sm font-black uppercase">{labelFor(category)}</p>
      <h1 class="mt-4 text-3xl font-black leading-tight sm:text-4xl">{item.title}</h1>
      <p class="mt-4 border-l-4 border-content-50 bg-base-950 px-3 py-3 text-sm font-bold leading-6 text-content-100 sm:px-4 sm:text-base sm:leading-7">{item.description || "Deskripsi belum tersedia."}</p>
      <div class="mt-7">
        <FavoriteButton item={{ id: item.id, type: `baca-${category}`, title: item.title, cover_url: item.cover_url, provider: item.provider }} />
      </div>
    </div>
  </section>
  <section class="mt-8">
    <h2 class="brutal-sticker mb-4 inline-block bg-yellow-500 px-3 py-1 text-2xl font-black">Chapter</h2>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {chapters.map((chapter) => <a class="brutal-card p-4 font-black" href={`/baca/${category}/${id}/read/${chapter.index}`}>Chapter {chapter.index}</a>)}
    </div>
  </section>
</AppShell>
