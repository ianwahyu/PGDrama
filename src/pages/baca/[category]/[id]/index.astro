---
import AppShell from "@components/AppShell.astro";
import FavoriteButton from "@components/FavoriteButton.astro";
import { isBacaCategory, labelFor } from "@lib/content";
import { getBacaChapters, getBacaDetail } from "@lib/splay";

const category = Astro.params.category ?? "";
const id = Astro.params.id ?? "";
if (!isBacaCategory(category)) {
  return Astro.redirect("/");
}

const [detail, chapters] = await Promise.all([getBacaDetail(category, id), getBacaChapters(category, id).catch(() => [])]);
const item = detail.item;
---

<AppShell title={`${item.title} - PGDrama`} compact>
  <a class="mb-5 inline-flex rounded-full bg-content-50/8 px-4 py-2 text-sm font-bold text-content-100/70" href={`/baca/${category}`}>← {labelFor(category)}</a>
  <section class="grid gap-6 md:grid-cols-[15rem_1fr]">
    <img class="poster-shadow aspect-[2/3] rounded-[1.6rem] object-cover" src={item.cover_url || ""} alt={item.title} />
    <div class="soft-panel rounded-[1.8rem] p-6">
      <p class="text-sm font-bold uppercase tracking-[0.24em] text-pink-300">{labelFor(category)}</p>
      <h1 class="mt-3 text-4xl font-black tracking-tight">{item.title}</h1>
      <p class="mt-4 leading-7 text-content-100/70">{item.description || "Deskripsi belum tersedia."}</p>
      <div class="mt-7">
        <FavoriteButton item={{ id: item.id, type: `baca-${category}`, title: item.title, cover_url: item.cover_url, provider: item.provider }} />
      </div>
    </div>
  </section>
  <section class="mt-8">
    <h2 class="mb-4 text-2xl font-black">Chapter</h2>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {chapters.map((chapter) => <a class="soft-panel rounded-2xl p-4 font-black hover:bg-content-50/12" href={`/baca/${category}/${id}/read/${chapter.index}`}>Chapter {chapter.index}</a>)}
    </div>
  </section>
</AppShell>
